# Cranker runtime configuration. Copy to `cranker.env` and fill in.
# All required vars are validated at boot by the Zod schema in
# packages/cranker/src/config.ts — boot fails fast if anything is wrong.

# Paid Solana mainnet RPC. PUBLIC mainnet-beta is REJECTED at boot
# because it disables getProgramAccounts which the scanner requires.
# Helius / QuickNode / Triton are known-good.
SOLANA_RPC_URL=https://your-paid-rpc.example.com
SOLANA_WS_URL=wss://your-paid-rpc.example.com

# FOGO RPC (mainnet, paid or self-hosted)
FOGO_RPC_URL=https://your-fogo-rpc.example.com

# Wormholescan API base. Default is the public hosted endpoint and is
# fine for production; override only if you run a private instance.
WORMHOLESCAN_URL=https://api.wormholescan.io

# Cranker keypair file (Solana JSON-array secret-key format).
# Mounted read-only from the host — see docker-compose.yml volume.
KEYPAIR_PATH=/secrets/cranker-keypair.json

# Network port for /metrics and /healthz. Bound 0.0.0.0 inside the
# container; compose binds 127.0.0.1:9090 on the host.
METRICS_PORT=9090

# Tuning knobs. Defaults shown.
SCAN_INTERVAL_MS=30000
RPC_TIMEOUT_MS=15000
WORMHOLESCAN_TIMEOUT_MS=10000
HEARTBEAT_STALE_MS=120000
MAX_CONCURRENT_ADVANCES=4
LOG_LEVEL=info
