{
  "name": "@fogo-onre/cranker",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Fogo-OnRe permissionless cranker daemon",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./advance": {
      "types": "./dist/advance/index.d.ts",
      "import": "./dist/advance/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anchor-lang/core": "^1.0.2",
    "@fogo-onre/sdk": "workspace:*",
    "@solana/web3.js": "^1.98.4",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
